rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // This security rules file assumes the following data structures:
    //
    // Collection: googleContactsCredentials
    // Document ID: {uid} (Firebase Auth UID)
    // Fields:
    //   - refreshToken: string (required, server-only secret, immutable to clients)
    //   - scope: string|null (optional, OAuth scope metadata)
    //   - accountEmail: string|null (optional, connected Google account email)
    //   - connectedAt: string (required, ISO 8601 timestamp string)
    //   - updatedAt: timestamp (required, server timestamp)
    //
    // The current Meishi app accesses Firestore only through Firebase Functions
    // using the Admin SDK. Browser clients are intentionally denied all access.
    //
    // ===============================================================

    match /googleContactsCredentials/{uid} {
      // Firestore stores refresh tokens and account metadata here.
      // All legitimate access goes through Firebase Functions/Admin SDK.
      // The schema is documented above, but browser clients are denied before
      // field-level validation because this app does not use the Firestore Web SDK.
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
