# Shared defaults loaded by Vite in every mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional. Defaults to us-central1 when omitted.
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional. Set to true to connect the browser app to local Firebase emulators.
VITE_FIREBASE_USE_EMULATORS=false

# Optional. Set these to enable PostHog analytics.
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=
